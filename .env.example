# Database (Postgres recommended for production; multi-tenant via org_id scoping)
DATABASE_URL="postgresql://user:password@localhost:5432/meetpilot?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-strong-random-secret"

# OAuth providers (sign-in)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# PM tool integrations (connected per-org via Settings > Integrations, OAuth 2.0)
JIRA_CLIENT_ID=""
JIRA_CLIENT_SECRET=""
LINEAR_CLIENT_ID=""
LINEAR_CLIENT_SECRET=""
ASANA_CLIENT_ID=""
ASANA_CLIENT_SECRET=""

# Video provider
GOOGLE_MEET_API_KEY=""
