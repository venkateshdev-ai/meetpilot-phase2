# Real DB (Supabase Postgres). App queries it over PostgREST at runtime
# (src/lib/db/supabase.ts) instead of @prisma/client, because this sandbox's
# network allowlist blocks the Prisma query-engine binary download. In a normal
# environment (Vercel, your own server) you can swap to @prisma/client using
# DATABASE_URL below with no schema changes — prisma/schema.prisma already
# matches the SQL migration applied to this project.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="your-anon-or-publishable-key"

# Only needed if/when you swap this build back to @prisma/client.
DATABASE_URL="postgresql://user:password@localhost:5432/meetpilot?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-strong-random-secret"

# OAuth providers (sign-in)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""

# Email (Resend) — used for "add member" invite emails and welcome-on-signup.
# Sign up free at resend.com, verify a sending domain (or use their
# onboarding@resend.dev sender to test, which only delivers to your own
# Resend account email). Without these set, signup/invite still work, the
# email step just no-ops and gets logged as FAILED in the EmailLog table.
RESEND_API_KEY=""
EMAIL_FROM="MeetPilot <onboarding@resend.dev>"

# LLM (Groq — OpenAI-compatible, free tier) — used to generate meeting
# summaries/action items/analytics from an uploaded transcript/notes file.
# Get a free key at console.groq.com/keys.
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# PM tool integrations — connected per-org from Admin > Integrations using a
# personal access token/API key you generate on each tool's own site, NOT a
# registered OAuth app (that's a heavier lift for a v1). Credentials are
# stored in the Integration table (accessTokenEnc), not here — these env vars
# aren't used; kept only as a reminder of what each integration needs:
#   Jira:   site URL + account email + API token (id.atlassian.com/manage-profile/security/api-tokens)
#   Asana:  Personal Access Token (asana.com/developers -> My Apps)
#   Trello: API key + token (trello.com/app-key)
#   Slack:  Bot token (api.slack.com/apps -> OAuth & Permissions)
