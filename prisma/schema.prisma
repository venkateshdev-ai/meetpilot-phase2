// MeetPilot data model
// Design principles:
// 1. Every business table is scoped by orgId -> hard multi-tenancy boundary, enforced in the
//    data-access layer (src/lib/db/*), not just at the app layer.
// 2. Role is stored on OrgMembership (a user can belong to multiple orgs with different roles),
//    not on User -> avoids the common "role is global" mistake that blocks multi-org scale.
// 3. Integration credentials are stored per-org, never per-user, and are referenced (not inlined)
//    from ActionItem so ticket-push audit trail survives integration reconnects.
// 4. AuditLog is append-only and indexed by orgId + createdAt for compliance/reporting queries.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ORG_ADMIN
  TEAM_LEAD
  MEMBER
  GUEST
}

enum MeetingType {
  ONLINE
  OFFLINE
  HYBRID
}

enum MeetingStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ActionItemStatus {
  OPEN
  IN_PROGRESS
  DONE
  BLOCKED
}

enum IntegrationProvider {
  JIRA
  ASANA
  TRELLO
  LINEAR
  GOOGLE_CALENDAR
  OUTLOOK_CALENDAR
  SLACK
  SALESFORCE
  HUBSPOT
  STRIPE
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  DONE
  BLOCKED
}

enum UploadStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum VisitorStatus {
  INVITED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
}

enum BookingStatus {
  BOOKED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

model Org {
  id           String         @id @default(cuid())
  name         String
  slug         String         @unique
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  memberships  OrgMembership[]
  rooms        Room[]
  desks        Desk[]
  meetings     Meeting[]
  integrations Integration[]
  auditLogs    AuditLog[]
  inviteCodes  InviteCode[]
  visitors     Visitor[]
  invoices     Invoice[]
  tickets      Ticket[]
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String?
  avatarUrl     String?
  passwordHash  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  memberships       OrgMembership[]
  createdMeetings   Meeting[]        @relation("MeetingCreatedBy")
  participations     MeetingParticipant[]
  assignedActions    ActionItem[]     @relation("ActionAssignee")
  bookings           RoomBooking[]    @relation("BookingCreatedBy")
  auditLogs          AuditLog[]
  connectedIntegrations Integration[] @relation("IntegrationConnectedBy")
  deskBookings        DeskBooking[]
  hostedVisitors      Visitor[]        @relation("VisitorHost")
  transcriptSegments  TranscriptSegment[]
  uploadedFiles       MeetingUpload[]  @relation("UploadedBy")
  createdTickets      Ticket[]         @relation("TicketCreatedBy")
  assignedTickets     Ticket[]         @relation("TicketAssignee")

  @@index([email])
}

// A user's membership + role within one org. This is the enterprise-correct place for RBAC.
model OrgMembership {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  role      Role     @default(MEMBER)
  createdAt DateTime @default(now())

  org  Org  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([orgId, role])
}

model InviteCode {
  id        String   @id @default(cuid())
  orgId     String
  code      String   @unique
  role      Role     @default(MEMBER)
  expiresAt DateTime?
  usesLeft  Int?
  createdAt DateTime @default(now())

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model Room {
  id         String   @id @default(cuid())
  orgId      String
  name       String
  capacity   Int
  areaSqft   Int?
  floor      String?
  zone       String?
  amenities  String[] @default([])
  tariffPerHour Decimal? @db.Decimal(10, 2)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  org      Org           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  bookings RoomBooking[]

  @@index([orgId])
}

model RoomBooking {
  id          String        @id @default(cuid())
  roomId      String
  meetingId   String?       @unique
  createdById String
  startTime   DateTime
  endTime     DateTime
  status      BookingStatus @default(BOOKED)
  checkInAt   DateTime?
  checkOutAt  DateTime?
  createdAt   DateTime      @default(now())

  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  meeting   Meeting? @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  createdBy User     @relation("BookingCreatedBy", fields: [createdById], references: [id])
  visitors  Visitor[]
  invoices  Invoice[]

  @@index([roomId, startTime])
}

model Meeting {
  id           String        @id @default(cuid())
  orgId        String
  title        String
  type         MeetingType
  status       MeetingStatus @default(SCHEDULED)
  agenda       String?
  meetLink     String?
  startTime    DateTime
  endTime      DateTime
  createdById  String
  // Video-call hosting details. Phase 1 stores a provider name + join URL only;
  // actually hosting a call requires a real WebRTC/video SDK (Daily.co, Twilio
  // Video, LiveKit) — see README "Going to production".
  callProvider String?
  callJoinUrl  String?
  // Stable hash of the sorted participant user-id set, used for MoM recall:
  // "has this exact group met before?" without an expensive join at read time.
  participantSetHash String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  org          Org                  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy    User                 @relation("MeetingCreatedBy", fields: [createdById], references: [id])
  participants MeetingParticipant[]
  roomBooking  RoomBooking?
  summary      MeetingSummary?
  actionItems  ActionItem[]
  transcript   TranscriptSegment[]
  uploads      MeetingUpload[]
  tickets      Ticket[]

  @@index([orgId, startTime])
  @@index([participantSetHash])
}

model MeetingParticipant {
  id        String   @id @default(cuid())
  meetingId String
  userId    String

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
}

model MeetingSummary {
  id                String   @id @default(cuid())
  meetingId         String   @unique
  executiveSummary  String?
  keyDecisions       String[] @default([])
  sentimentTrend     Json?    // [{ tMinutes, score }]
  talkTimeByUser     Json?    // { userId: minutes }
  meetingRoiPercent  Int?
  topicsJson         Json?    // [{ topic, weight }]
  consentGiven       Boolean  @default(false)
  generatedAt        DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model ActionItem {
  id            String            @id @default(cuid())
  meetingId     String
  description   String
  assigneeId    String?
  dueDate       DateTime?
  status        ActionItemStatus  @default(OPEN)
  syncedProvider IntegrationProvider?
  syncedTicketId String?
  syncedTicketUrl String?
  syncedStatus   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  meeting  Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  assignee User?   @relation("ActionAssignee", fields: [assigneeId], references: [id])
  tickets  Ticket[]

  @@index([meetingId])
  @@index([assigneeId, status])
}

// Per-org connection to a PM tool. For OAuth providers, tokens go in
// accessTokenEnc/refreshTokenEnc (encrypted at the application layer before
// being written here — see src/lib/integrations/crypto.ts). For the
// personal-access-token providers this app actually wires up (Jira, Asana,
// Trello, Slack), the PAT/API key is stored in accessTokenEnc the same way,
// and `config` holds the non-secret per-provider settings needed to route
// calls (Jira: siteUrl + userEmail + projectKey; Asana: projectGid; Trello:
// apiKey + boardId — trelloapi actually needs two secrets, key+token, both
// go in accessTokenEnc as "key:token"; Slack: channelId).
model Integration {
  id                 String              @id @default(cuid())
  orgId              String
  provider           IntegrationProvider
  accessTokenEnc     String
  refreshTokenEnc    String?
  scope              String?
  config             Json?
  expiresAt          DateTime?
  connectedById      String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  org         Org  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  connectedBy User @relation("IntegrationConnectedBy", fields: [connectedById], references: [id])

  @@unique([orgId, provider])
}

// A file (transcript, notes doc, etc.) uploaded against a meeting so an LLM
// can generate a summary + action items + light analytics from it, as an
// alternative/supplement to live transcription. extractedText is the
// plain-text content pulled from the upload (txt/docx/pdf) before it's sent
// to the model — see src/lib/ai/summarize.ts.
model MeetingUpload {
  id            String       @id @default(cuid())
  meetingId     String
  uploadedById  String
  fileName      String
  mimeType      String?
  sizeBytes     Int?
  extractedText String?
  status        UploadStatus @default(PENDING)
  errorMessage  String?
  createdAt     DateTime     @default(now())
  processedAt   DateTime?

  meeting    Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation("UploadedBy", fields: [uploadedById], references: [id])

  @@index([meetingId])
}

// A fully-specced work item, richer than ActionItem. Created from a meeting's
// action items (or from scratch) and optionally pushed to a connected PM
// tool. Because Jira/Asana/Trello don't have native fields for
// "why scenario" or "success metric", the push adapters
// (src/lib/integrations/*.ts) format all of these into the target ticket's
// description as labeled sections — this table is the source of truth.
model Ticket {
  id                 String              @id @default(cuid())
  orgId              String
  meetingId          String?
  actionItemId       String?
  title              String
  description        String?
  whyScenario        String?
  featureDescription String?
  testCases          String?
  acceptanceCriteria String?
  telemetry          String?
  successMetric      String?
  status             TicketStatus        @default(OPEN)
  assigneeId         String?
  createdById        String
  provider           IntegrationProvider?
  externalId         String?
  externalUrl        String?
  externalStatus     String?
  lastSyncedAt       DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  org        Org         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  meeting    Meeting?    @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  actionItem ActionItem? @relation(fields: [actionItemId], references: [id], onDelete: SetNull)
  assignee   User?       @relation("TicketAssignee", fields: [assigneeId], references: [id])
  createdBy  User        @relation("TicketCreatedBy", fields: [createdById], references: [id])

  @@index([orgId])
  @@index([meetingId])
}

// Append-only send log for outbound email (invites, add-user notifications).
// Kept simple on purpose — this is an audit trail, not a queue.
model EmailLog {
  id           String   @id @default(cuid())
  toEmail      String
  type         String
  status       String
  errorMessage String?
  createdAt    DateTime @default(now())
}

// Hot-desk (as opposed to a bookable meeting Room). Distinct model because desks
// are booked per-day by a single user, not per-timeslot by a meeting.
model Desk {
  id        String   @id @default(cuid())
  orgId     String
  label     String
  floor     String
  zone      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  org      Org           @relation(fields: [orgId], references: [id], onDelete: Cascade)
  bookings DeskBooking[]

  @@index([orgId])
}

model DeskBooking {
  id          String        @id @default(cuid())
  deskId      String
  userId      String
  date        DateTime
  startTime   DateTime
  endTime     DateTime
  status      BookingStatus @default(BOOKED)
  checkInAt   DateTime?
  checkOutAt  DateTime?
  createdAt   DateTime      @default(now())

  desk Desk @relation(fields: [deskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([deskId, date])
}

// Front-desk / visitor management. Optionally attached to a RoomBooking so the
// host's meeting shows "1 external guest checking in" automatically.
model Visitor {
  id            String        @id @default(cuid())
  orgId         String
  name          String
  email         String
  hostUserId    String
  roomBookingId String?
  purpose       String?
  badgeCode     String?
  status        VisitorStatus @default(INVITED)
  expectedAt    DateTime
  checkedInAt   DateTime?
  checkedOutAt  DateTime?
  createdAt     DateTime      @default(now())

  org         Org          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  host        User         @relation("VisitorHost", fields: [hostUserId], references: [id])
  roomBooking RoomBooking? @relation(fields: [roomBookingId], references: [id])

  @@index([orgId, expectedAt])
}

// Invoicing for paid/external room or desk usage. Real implementation charges
// via Stripe Billing and this table mirrors the resulting invoice object.
model Invoice {
  id            String        @id @default(cuid())
  orgId         String
  number        String        @unique
  description   String
  amount        Decimal       @db.Decimal(10, 2)
  currency      String        @default("INR")
  status        InvoiceStatus @default(DRAFT)
  issuedAt      DateTime      @default(now())
  dueAt         DateTime?
  roomBookingId String?
  createdAt     DateTime      @default(now())

  org         Org          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  roomBooking RoomBooking? @relation(fields: [roomBookingId], references: [id])

  @@index([orgId, status])
}

// Live transcript feed for a meeting's video call. Real implementation is
// streamed in near-real-time from a transcription provider (AssemblyAI,
// Deepgram, Whisper) via the call SDK's audio track, one segment per utterance.
model TranscriptSegment {
  id            String   @id @default(cuid())
  meetingId     String
  speakerUserId String?
  text          String
  tMinutes      Float
  createdAt     DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  speaker User?   @relation(fields: [speakerUserId], references: [id])

  @@index([meetingId, tMinutes])
}

model AuditLog {
  id        String   @id @default(cuid())
  orgId     String
  actorId   String?
  action    String
  targetType String
  targetId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  org   Org   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  actor User? @relation(fields: [actorId], references: [id])

  @@index([orgId, createdAt])
}
